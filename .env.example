# Clé API Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Port du serveur
PORT=3001

# Token admin (waitlist) — à changer en production
ADMIN_TOKEN=change-moi-en-prod

# Authentification JWT
JWT_SECRET=change-moi-en-production
JWT_EXPIRES_IN=7d

# SMTP Gmail (utilise un App Password, pas ton mot de passe Google)
# Le serveur retire automatiquement les espaces du SMTP_PASS (App Password = 16 caractères).
SMTP_USER=studioarkenpro@gmail.com
SMTP_PASS=ton-app-password-gmail

# URL publique de l'application (pour les liens dans les emails)
# ⚠ Sur Railway : mets l'URL publique du service, ex. https://praxi.up.railway.app
APP_URL=http://localhost:3001

# Dossier de stockage des données (waitlist.json / users.json).
# ⚠ Sur Railway : le disque est éphémère. Monte un volume (ex. /data) et définis
# DATA_DIR=/data pour que les comptes et les réinitialisations persistent.
# DATA_DIR=/data
